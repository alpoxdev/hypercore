{
  "name": "@kood/claude-code",
  "version": "0.5.2",
  "description": "Claude Code documentation installer for projects",
  "type": "module",
  "bin": "./dist/index.js",
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "copy-templates": "node scripts/copy-templates.js",
    "build": "yarn tsup && yarn run copy-templates",
    "dev": "yarn run build && node dist/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "prepublishOnly": "yarn run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "documentation",
    "cli",
    "tanstack",
    "hono"
  ],
  "author": "alpoxdev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/alpoxdev/claude-code"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
